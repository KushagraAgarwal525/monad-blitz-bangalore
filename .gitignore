# =============================================================================
# Memoria / MemoryOS — root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
credentials.json
secrets.json
.secrets/

# -----------------------------------------------------------------------------
# Node.js / Next.js (web/)
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.turbo
.vercel
*.tsbuildinfo

# Next.js
.next/
out/
build/
dist/
coverage/
.nyc_output/

# Auto-generated by Next.js (recreated on `npm run dev`)
web/next-env.d.ts

# -----------------------------------------------------------------------------
# Python (backend/, scripts/)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.envrc
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.egg
*.egg-info/
.eggs/
*.manifest
*.spec
pip-wheel-metadata/
share/python-wheels/
instance/
.webassets-cache
celerybeat-schedule
celerybeat.pid
*.mo
*.pot
db.sqlite3
db.sqlite3-journal

# -----------------------------------------------------------------------------
# Foundry / Solidity (contracts/)
# -----------------------------------------------------------------------------
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/lib/

# -----------------------------------------------------------------------------
# Docker & local data volumes
# -----------------------------------------------------------------------------
docker-data/
postgres-data/
qdrant-data/
*.volume

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.settings/

# Cursor (local plans, debug state — not part of the submission)
.cursor/

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Agent / local tooling (optional dev-only skills)
# -----------------------------------------------------------------------------
.agents/

# -----------------------------------------------------------------------------
# Misc build & package artifacts
# -----------------------------------------------------------------------------
*.tar.gz
*.zip
*.rar
.cache/
.parcel-cache/
.sass-cache/
.eslintcache
.stylelintcache
storybook-static/
*.local
