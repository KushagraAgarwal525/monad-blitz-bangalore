# PostgreSQL
DATABASE_URL=postgresql+asyncpg://memoria:memoria@localhost:5432/memoria

# Qdrant
QDRANT_URL=http://localhost:6333

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_CHAT_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_EMBEDDING_MODEL=fireworks/qwen3-embedding-8b
FIREWORKS_EMBEDDING_DIMENSIONS=1536

# Monad
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Backend signer (same wallet that owns repos you sync on-chain)
PRIVATE_KEY=

# Contract addresses (fill after deploy)
MEMORY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
MEMORY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
LICENSE_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
ROYALTY_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
MEMORY_SCORE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Hackathon demo flow (remove after hackathon)
ENABLE_DEMO_FLOW=false
DEMO_PARENT_PRIVATE_KEY=
DEMO_FORKER_PRIVATE_KEY=
DEMO_BUYER_PRIVATE_KEY=

# Frontend (also copy to web/.env.local for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_DEMO_FLOW=false
NEXT_PUBLIC_CHAIN_ID=143
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz

# Optional: auto-connect in browser (DEV ONLY — key is visible in client bundle)
# Prefer "Connect with key" in the UI, or MetaMask with imported account.
NEXT_PUBLIC_DEV_WALLET_PRIVATE_KEY=
NEXT_PUBLIC_DEV_WALLET_ADDRESS=
