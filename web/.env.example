# Local Next.js — copy from repo root .env or set manually
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHAIN_ID=143
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_MEMORY_TOKEN_ADDRESS=
NEXT_PUBLIC_MEMORY_REGISTRY_ADDRESS=
NEXT_PUBLIC_LICENSE_MANAGER_ADDRESS=
NEXT_PUBLIC_ENABLE_DEMO_FLOW=false

# Production (Vercel dashboard) — use ONE of:
#   A) Direct backend (recommended for agent/LLM — no proxy timeout):
#      NEXT_PUBLIC_API_URL=https://your-api.onrender.com
#   B) Same-origin proxy (set API_PROXY_URL on Vercel, leave NEXT_PUBLIC unset):
#      API_PROXY_URL=https://your-api.onrender.com
#      (NEXT_PUBLIC_API_URL omitted → defaults to /api in production)
